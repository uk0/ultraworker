# Ultrawork Environment Variables

# Agentic task timeout in seconds (default: 86400 = 24 hours)
ULTRAWORK_AGENTIC_TIMEOUT=86400

# Slack tokens (if not using MCP)
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_USER_TOKEN=xoxp-...

# memory-search binary path (leave empty for auto-detect)
# MEMORY_SEARCH_BIN=/Users/admin/memory-search/target/release/memory-search

# Optional memory-search source settings for setup wizard
# MEMORY_SEARCH_REPO_DIR=/Users/admin/memory-search
# MEMORY_SEARCH_REPO_URL=https://github.com/<org>/memory-search.git
