# Ultrawork Environment Variables

# Agentic task timeout in seconds (default: 86400 = 24 hours)
ULTRAWORK_AGENTIC_TIMEOUT=86400

# Slack tokens (if not using MCP)
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_USER_TOKEN=xoxp-...

# memory-search binary path (leave empty for auto-detect)
# MEMORY_SEARCH_BIN=/absolute/path/to/ultraworker/vendor/memory-search/target/release/memory-search

# Optional memory-search source settings for setup wizard
# MEMORY_SEARCH_REPO_DIR=/absolute/path/to/ultraworker/vendor/memory-search
# MEMORY_SEARCH_REPO_URL=https://github.com/<org>/memory-search.git

# Optional: TEI (BGE-M3 embedding) runtime for memory-search
# MEMORY_SEARCH_TEI_ENDPOINT=http://127.0.0.1:8080
# MEMORY_SEARCH_TEI_MODEL=BAAI/bge-m3
# MEMORY_SEARCH_TEI_AUTOSTART=true
# MEMORY_SEARCH_TEI_LOCAL_AUTOSTART=true
# MEMORY_SEARCH_TEI_DOCKER_AUTOSTART=true
# MEMORY_SEARCH_TEI_PORT=8080
# MEMORY_SEARCH_TEI_BIN=text-embeddings-router
# MEMORY_SEARCH_TEI_ARGS=
# MEMORY_SEARCH_TEI_LOG_PATH=/absolute/path/to/ultraworker/data/memory/index/tei-router.log
# MEMORY_SEARCH_TEI_DOCKER_IMAGE=ghcr.io/huggingface/text-embeddings-inference:cpu-latest

# Optional: local Qdrant runtime for memory-search
# MEMORY_SEARCH_QDRANT_ENDPOINT=http://127.0.0.1:6333
# MEMORY_SEARCH_QDRANT_AUTOSTART=true
# MEMORY_SEARCH_QDRANT_LOCAL_AUTOSTART=true
# MEMORY_SEARCH_QDRANT_DOCKER_AUTOSTART=true
# MEMORY_SEARCH_QDRANT_PORT=6333
# MEMORY_SEARCH_QDRANT_GRPC_PORT=6334
# MEMORY_SEARCH_QDRANT_COLLECTION=memory_records_v1
# MEMORY_SEARCH_QDRANT_PATH=/absolute/path/to/ultraworker/data/memory/index/qdrant/storage
# MEMORY_SEARCH_QDRANT_BIN=qdrant
# MEMORY_SEARCH_QDRANT_VERSION=v1.17.0
# MEMORY_SEARCH_QDRANT_ARGS=
# MEMORY_SEARCH_QDRANT_LOG_PATH=/absolute/path/to/ultraworker/data/memory/index/qdrant.log
# MEMORY_SEARCH_QDRANT_DOCKER_IMAGE=qdrant/qdrant:latest
