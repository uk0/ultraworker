{
  "mcpServers": {
    "slack": {
      "command": "npx",
      "args": [
        "-y",
        "@jtalk22/slack-mcp"
      ],
      "env": {
        "SLACK_TOKEN": "xoxc-your-personal-token-here",
        "SLACK_COOKIE": "xoxd-your-cookie-here"
      }
    },
    "slack-bot-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "slack-bot-mcp"
      ],
      "env": {
        "SLACK_BOT_TOKEN": "xoxb-your-bot-token-here"
      }
    },
    "memory-search": {
      "command": "/absolute/path/to/ultraworker/vendor/memory-search/target/release/memory-search",
      "args": [
        "serve",
        "--data-dir",
        "/absolute/path/to/ultraworker/data"
      ]
    }
  }
}
